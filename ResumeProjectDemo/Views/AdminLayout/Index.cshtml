@{
    Layout = null;
}

<!DOCTYPE html>
<html class="dark" lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Developer Portfolio Admin Dashboard</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&amp;display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
        darkMode: "class",
        theme: {
        extend: {
        colors: {
        "primary": "#13b6ec",
        "background-light": "#f6f8f8",
        "background-dark": "#101d22",
        },
        fontFamily: {
        "display": ["Space Grotesk", "sans-serif"]
        },
        borderRadius: {
        "DEFAULT": "0.25rem",
        "lg": "0.5rem",
        "xl": "0.75rem",
        "full": "9999px"
        },
        },
        },
        }
    </script>
    <style>
        body {
        font-family: 'Space Grotesk', sans-serif;
        }

        .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
    </style>
</head>
<body class="bg-background-light dark:bg-background-dark text-slate-900 dark:text-slate-100 min-h-screen flex">

    <!-- Sidebar -->
    <aside class="w-64 flex-shrink-0 bg-white dark:bg-[#111618] border-r border-slate-200 dark:border-[#283539] flex flex-col">
        <div class="p-6 flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-primary flex items-center justify-center text-background-dark font-bold text-xl">FZ</div>
            <div class="flex flex-col">
                <h1 class="text-sm font-bold leading-tight">Full Stack Dev</h1>
                <p class="text-xs text-slate-500 dark:text-[#9db2b9]">Admin Portal</p>
            </div>
        </div>
        <nav class="flex-1 px-4 py-2 space-y-1 overflow-y-auto">

            <a asp-controller="Dashboard" asp-action="Index"
                   class="flex items-center gap-3 px-3 py-2 rounded-lg text-slate-600 dark:text-[#9db2b9] hover:bg-slate-100 dark:hover:bg-[#1c2427] transition-colors">
                <span class="material-symbols-outlined text-[22px]">dashboard</span>
                <span class="text-sm font-medium">Panel</span>
            </a>

            <a asp-controller="About" asp-action="AboutList"
                   class="flex items-center gap-3 px-3 py-2 rounded-lg text-slate-600 dark:text-[#9db2b9] hover:bg-slate-100 dark:hover:bg-[#1c2427] transition-colors">
                <span class="material-symbols-outlined text-[22px]">person</span>
                <span class="text-sm font-medium">Hakkımda</span>
            </a>

            <a asp-controller="Skill" asp-action="SkillList"
                   class="flex items-center gap-3 px-3 py-2 rounded-lg text-slate-600 dark:text-[#9db2b9] hover:bg-slate-100 dark:hover:bg-[#1c2427] transition-colors">
                <span class="material-symbols-outlined text-[22px]">psychology</span>
                <span class="text-sm font-medium">Yetenekler</span>
            </a>

            <a asp-controller="Experience" asp-action="ExperienceList"
                   class="flex items-center gap-3 px-3 py-2 rounded-lg text-slate-600 dark:text-[#9db2b9] hover:bg-slate-100 dark:hover:bg-[#1c2427] transition-colors">
                <span class="material-symbols-outlined text-[22px]">work</span>
                <span class="text-sm font-medium">Deneyimler</span>
            </a>

            <a asp-controller="Service" asp-action="ServiceList"
                   class="flex items-center gap-3 px-3 py-2 rounded-lg text-slate-600 dark:text-[#9db2b9] hover:bg-slate-100 dark:hover:bg-[#1c2427] transition-colors">
                <span class="material-symbols-outlined text-[22px]">verified</span>
                <span class="text-sm font-medium">Hizmetlerim</span>
            </a>

            <a asp-controller="Portfolio" asp-action="PortfolioList"
                   class="flex items-center gap-3 px-3 py-2 rounded-lg text-slate-600 dark:text-[#9db2b9] hover:bg-slate-100 dark:hover:bg-[#1c2427] transition-colors">
                <span class="material-symbols-outlined text-[22px]" style="font-variation-settings: 'FILL' 1">folder</span>
                <span class="text-sm font-medium">Projelerim</span>
            </a>

            <a asp-controller="Testimonial" asp-action="TestimonialList"
                   class="flex items-center gap-3 px-3 py-2 rounded-lg text-slate-600 dark:text-[#9db2b9] hover:bg-slate-100 dark:hover:bg-[#1c2427] transition-colors">
                <span class="material-symbols-outlined text-[22px]">format_quote</span>
                <span class="text-sm font-medium">Referanslar</span>
            </a>

            <a asp-controller="Message" asp-action="MessageList"
                   class="flex items-center gap-3 px-3 py-2 rounded-lg text-slate-600 dark:text-[#9db2b9] hover:bg-slate-100 dark:hover:bg-[#1c2427] transition-colors">
                <span class="material-symbols-outlined text-[22px]">mail</span>
                <span class="text-sm font-medium">Mesajlar</span>
            </a>

        </nav>
    </aside>

    <!-- Main Content Area -->
    <main class="flex-1 flex flex-col min-w-0 bg-background-light dark:bg-background-dark">
        <!-- Top Navbar -->
        <header class="h-16 flex items-center justify-between px-8 bg-white dark:bg-[#111618] border-b border-slate-200 dark:border-[#283539] z-10 flex-shrink-0">
            <div class="flex items-center gap-2">
                <span class="material-symbols-outlined text-primary">terminal</span>
                <h2 class="text-lg font-bold tracking-tight">Developer Admin Panel</h2>
            </div>
            <div class="flex items-center gap-6">
                <div class="relative">

                    <button onclick="toggleMessages()"
                            class="relative p-2 text-slate-500 dark:text-[#9db2b9] hover:bg-slate-100 dark:hover:bg-[#283539] rounded-lg transition-colors">

                        <span class="material-symbols-outlined text-[22px]">mail</span>

                        <span class="absolute top-2 right-2.5 w-2 h-2 bg-primary rounded-full border-2 border-white dark:border-[#111618]">
                            @await Component.InvokeAsync("NewMessageCount")
                        </span>

                    </button>

                    <div id="messageDropdown" class="hidden">
                        @await Component.InvokeAsync("UnreadMessagesComponent")
                    </div>

                </div>
                <div class="flex items-center gap-3 pl-4 border-l border-slate-200 dark:border-[#283539]">
                    <div class="text-right hidden sm:block">
                        <p class="text-xs font-bold">Furkan Zihni</p>
                        <p class="text-[10px] text-primary">Full Stack Developer</p>
                    </div>
                    <div class="w-10 h-10 rounded-full bg-slate-200 bg-cover bg-center" style="background-image: url('/images/images5.jpg');"></div>
                </div>
            </div>
        </header>

        <!-- Scrollable Body -->
        <div class="flex-1 overflow-auto">
            @RenderBody()
        </div>

        <!-- Float Action Button for Mobile / Quick Access -->
        <div class="fixed bottom-8 right-8 lg:hidden">
            <button class="w-14 h-14 bg-primary rounded-full shadow-lg flex items-center justify-center text-background-dark hover:scale-105 transition-transform">
                <span class="material-symbols-outlined text-[30px]">add</span>
            </button>
        </div>
    </main>
    <script>
        function toggleMessages() {
        var dropdown = document.getElementById("messageDropdown");
        dropdown.classList.toggle("hidden");
        }
    </script>
</body>
</html>