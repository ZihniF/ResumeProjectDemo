@model ResumeProjectDemo.Entities.Portfolio
@{
    ViewData["Title"] = "UpdatePortfolio";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<div class="flex-1 overflow-y-auto p-8">
    <div class="max-w-3xl mx-auto space-y-8">

        <div>
            <h3 class="text-3xl font-black tracking-tight">Proje Güncelle</h3>
        </div>

        <div class="bg-white dark:bg-[#111618] rounded-xl border border-slate-200 dark:border-[#3b4d54] p-8 shadow-sm">

            <form method="post">

                <input type="hidden" asp-for="PortfolioId" />

                <div class="grid grid-cols-1 gap-6">

                    <div>
                        <label class="text-sm font-semibold">Proje Başlığı</label>
                        <input asp-for="Title"
                               class="mt-2 w-full px-4 py-2 border rounded-lg bg-transparent" />
                    </div>

                    <div>
                        <label class="text-sm font-semibold">Görsel Url</label>
                        <input asp-for="ImageUrl"
                               class="mt-2 w-full px-4 py-2 border rounded-lg bg-transparent" />
                    </div>

                    <div>
                        <label class="text-sm font-semibold">Kategori</label>
                        <select asp-for="CategoryId"
                                asp-items="ViewBag.categories"
                                class="mt-2 w-full px-4 py-2 border rounded-lg bg-transparent">
                        </select>
                    </div>

                </div>

                <div class="mt-8 flex gap-3">

                    <button class="px-6 py-2 bg-green-500 text-white rounded-lg font-bold text-sm">
                        Güncelle
                    </button>

                    <a href="/Portfolio/PortfolioList/"
                       class="px-6 py-2 bg-slate-400 text-white rounded-lg text-sm">
                        Vazgeç
                    </a>

                </div>

            </form>

        </div>

    </div>
</div>

