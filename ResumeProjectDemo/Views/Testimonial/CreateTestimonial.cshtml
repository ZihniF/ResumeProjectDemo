@model ResumeProjectDemo.Entities.Testimonial
@{
    ViewData["Title"] = "CreateTestimonial";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<div class="flex-1 overflow-y-auto p-8">
    <div class="max-w-3xl mx-auto space-y-8">

        <!-- Heading -->
        <div>
            <h3 class="text-3xl font-black tracking-tight">Yeni Referans Ekle</h3>
            <p class="text-slate-500 dark:text-[#9db2b9] mt-1">
                Referans bilgilerini girerek yeni bir yorum ekleyebilirsiniz.
            </p>
        </div>

        <!-- Form -->
        <div class="bg-white dark:bg-[#111618] rounded-xl border border-slate-200 dark:border-[#3b4d54] p-8 shadow-sm">

            <form method="post">

                <div class="grid grid-cols-1 gap-6">

                    <div>
                        <label class="text-sm font-semibold">Ad Soyad</label>
                        <input type="text" asp-for="NameSurname"
                               class="mt-2 w-full px-4 py-2 border rounded-lg bg-transparent" />
                    </div>

                    <div>
                        <label class="text-sm font-semibold">Ünvan / Şirket</label>
                        <input type="text" asp-for="TitleAndCompany"
                               class="mt-2 w-full px-4 py-2 border rounded-lg bg-transparent" />
                    </div>

                    <div>
                        <label class="text-sm font-semibold">Fotoğraf Url</label>
                        <input type="text" asp-for="ImageUrl"
                               class="mt-2 w-full px-4 py-2 border rounded-lg bg-transparent" />
                    </div>

                    <div>
                        <label class="text-sm font-semibold">Yorum</label>
                        <textarea asp-for="CommendDetail"
                                  rows="4"
                                  class="mt-2 w-full px-4 py-2 border rounded-lg bg-transparent"></textarea>
                    </div>

                    <div class="flex items-center gap-2">
                        <input type="checkbox" asp-for="IsConfirm" />
                        <label class="text-sm">Onaylı mı?</label>
                    </div>

                </div>

                <div class="mt-8 flex gap-3">

                    <button type="submit"
                            class="px-6 py-2 bg-primary text-background-dark rounded-lg font-bold text-sm hover:opacity-90">
                        Kaydet
                    </button>

                    <a href="/Testimonial/TestimonialList/"
                       class="px-6 py-2 bg-slate-400 text-white rounded-lg text-sm">
                        Vazgeç
                    </a>

                </div>

            </form>

        </div>

    </div>
</div>

