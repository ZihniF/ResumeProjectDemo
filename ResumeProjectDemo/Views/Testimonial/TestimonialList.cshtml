@model List<ResumeProjectDemo.Entities.Testimonial>
@{
    ViewData["Title"] = "TestimonialList";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<div class="flex-1 overflow-y-auto p-8">
    <div class="max-w-6xl mx-auto space-y-8">

        <!-- Page Heading -->
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
            <div>
                <h3 class="text-3xl font-black tracking-tight">Referans Listesi</h3>
                <p class="text-slate-500 dark:text-[#9db2b9] mt-1">
                    Referans yorumlarını yönetebilir, onaylayabilir veya reddedebilirsiniz.
                </p>
            </div>

            <a href="/Testimonial/CreateTestimonial/"
               class="flex items-center gap-2 px-5 py-2.5 bg-primary text-background-dark rounded-lg font-bold text-sm hover:opacity-90 transition-opacity">
                <span class="material-symbols-outlined text-[20px]">add</span>
                Yeni Referans
            </a>
        </div>

        <!-- Table -->
        <div class="bg-white dark:bg-[#111618] rounded-xl border border-slate-200 dark:border-[#3b4d54] overflow-hidden shadow-sm">

            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">

                    <thead>
                        <tr class="bg-slate-50 dark:bg-[#1c2427] border-b border-slate-200 dark:border-[#3b4d54]">

                            <th class="px-6 py-4 text-xs font-bold uppercase">#</th>
                            <th class="px-6 py-4 text-xs font-bold uppercase">Fotoğraf</th>
                            <th class="px-6 py-4 text-xs font-bold uppercase">Ad Soyad</th>
                            <th class="px-6 py-4 text-xs font-bold uppercase">Ünvan / Şirket</th>
                            <th class="px-6 py-4 text-xs font-bold uppercase">Yorum</th>
                            <th class="px-6 py-4 text-xs font-bold uppercase">Durum</th>
                            <th class="px-6 py-4 text-xs font-bold uppercase text-center">Onayla</th>
                            <th class="px-6 py-4 text-xs font-bold uppercase text-center">Reddet</th>
                            <th class="px-6 py-4 text-xs font-bold uppercase text-right">Sil</th>
                            <th class="px-6 py-4 text-xs font-bold uppercase text-right">Güncelle</th>

                        </tr>
                    </thead>

                    <tbody class="divide-y divide-slate-200 dark:divide-[#3b4d54]">

                        @foreach (var item in Model)
                        {
                            <tr class="hover:bg-slate-50/50 dark:hover:bg-white/5 transition-colors">

                                <td class="px-6 py-5 font-semibold text-sm">
                                    @item.TestimonialId
                                </td>

                                <td class="px-6 py-5">
                                    <img src="@item.ImageUrl"
                                         class="w-12 h-12 rounded-full object-cover border" />
                                </td>

                                <td class="px-6 py-5 font-semibold text-sm">
                                    @item.NameSurname
                                </td>

                                <td class="px-6 py-5 text-sm">
                                    @item.TitleAndCompany
                                </td>

                                <td class="px-6 py-5 text-sm max-w-xs truncate">
                                    @item.CommendDetail
                                </td>

                                <td class="px-6 py-5">

                                    @if (item.IsConfirm)
                                    {
                                        <span class="px-2 py-1 text-xs bg-green-100 text-green-700 rounded">
                                            Onaylı
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="px-2 py-1 text-xs bg-yellow-100 text-yellow-700 rounded">
                                            Bekliyor
                                        </span>
                                    }

                                </td>

                                <!-- Onayla -->
                                <td class="px-6 py-5 text-center">

                                    <a href="/Testimonial/ChangeStatus/@item.TestimonialId?status=true"
                                       class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-blue-500 hover:bg-blue-600 text-white rounded-lg text-xs">
                                        Onayla
                                    </a>

                                </td>

                                <!-- Reddet -->
                                <td class="px-6 py-5 text-center">

                                    <a href="/Testimonial/ChangeStatus/@item.TestimonialId?status=false"
                                       class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-yellow-500 hover:bg-yellow-600 text-white rounded-lg text-xs">
                                        Reddet
                                    </a>

                                </td>

                                <!-- Sil -->
                                <td class="px-6 py-5 text-right">

                                    <a href="/Testimonial/DeleteTestimonial/@item.TestimonialId"
                                       class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-red-500 hover:bg-red-600 text-white rounded-lg text-xs">

                                        Sil
                                    </a>

                                </td>

                                <!-- Güncelle -->
                                <td class="px-6 py-5 text-right">

                                    <a href="/Testimonial/UpdateTestimonial/@item.TestimonialId"
                                       class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-green-500 hover:bg-green-600 text-white rounded-lg text-xs">

                                        Güncelle
                                    </a>

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>
            </div>

            <!-- Footer -->
            <div class="px-6 py-4 bg-slate-50/30 dark:bg-[#1c2427]/30 border-t border-slate-200 dark:border-[#3b4d54]">
                <p class="text-xs text-slate-500">
                    Toplam @Model.Count Referans Bulunmaktadır.
                </p>
            </div>

        </div>
    </div>
</div>